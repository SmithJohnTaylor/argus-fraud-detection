# Together AI Configuration
TOGETHER_API_KEY=your_together_api_key_here

# Confluent Cloud Configuration (Required)
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-west-2.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your_confluent_api_key
CONFLUENT_API_SECRET=your_confluent_api_secret
CONFLUENT_SECURITY_PROTOCOL=SASL_SSL
CONFLUENT_SASL_MECHANISM=PLAIN
CONFLUENT_SSL_ENDPOINT_IDENTIFICATION_ALGORITHM=https

# Kafka Topics and Configuration
KAFKA_TOPIC_TRANSACTIONS=financial-transactions
KAFKA_TOPIC_DECISIONS=ai-decisions
KAFKA_TOPIC_ALERTS=alerts
KAFKA_GROUP_ID=fraud-detection-group
KAFKA_CLIENT_ID=financial-transaction-producer

# Database Configuration (if using a database for persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/fraud_detection

# Alert Configuration
# Currently alerts are logged to console and stored in-memory
# External notifications (email, SMS, Slack) can be added as future enhancements

# Application Configuration
LOG_LEVEL=INFO
DEBUG=False

# Security Configuration
SECRET_KEY=your_secret_key_for_session_management
API_RATE_LIMIT=100  # requests per minute

# Dashboard Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
AUTO_REFRESH_INTERVAL=10  # seconds

# Risk Scoring Configuration
DEFAULT_RISK_THRESHOLD=0.5
HIGH_RISK_THRESHOLD=0.7
CRITICAL_RISK_THRESHOLD=0.9

# Transaction Limits
MAX_TRANSACTION_AMOUNT=50000
VELOCITY_CHECK_WINDOW=3600  # seconds (1 hour)
MAX_TRANSACTIONS_PER_HOUR=10

# Geographic Risk Configuration
HIGH_RISK_COUNTRIES=XX,IR,KP,SY,AF
DOMESTIC_COUNTRY=USA

# Model Configuration
TOGETHER_MODEL=meta-llama/Llama-3.2-90B-Vision-Instruct-Turbo
MAX_TOKENS=2000
TEMPERATURE=0.1

# Monitoring and Observability
SENTRY_DSN=your_sentry_dsn_here
PROMETHEUS_METRICS_PORT=9090

# Production Settings
CONSOLE_ALERTS=true  # Set to true to enable console logging of alerts
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_REQUEST_TIMEOUT_MS=40000
KAFKA_RETRY_BACKOFF_MS=1000